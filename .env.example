# .env.example  –  Copy to .env and fill in real values
# Never commit the real .env file.

# ── Scraper ────────────────────────────────────────────────────
WUZZUF_BASE_URL=https://wuzzuf.net/search/jobs/
SCRAPE_MAX_PAGES=50
SCRAPE_HEADLESS=true
SCRAPE_REQUEST_DELAY_SECONDS=2.5

# ── Output ─────────────────────────────────────────────────────
OUTPUT_DIR=output
STATE_FILE=pipeline/state/checkpoint.json

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
